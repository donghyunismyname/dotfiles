# Workarounds for shared linuxbrew on Linux (brew is single-user by design,
# so brew's zsh site-functions end up owned by another user).
#
# 1. Skip /etc/zsh/zshrc's global compinit call (zsh builtin check).
skip_global_compinit=1
# 2. Tell oh-my-zsh to skip its own compaudit (read later in .zshrc).
ZSH_DISABLE_COMPFIX=true
