# ============================================
# PATH
# ============================================

# Homebrew (Linux) - must be first
if [[ -f /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# ~/.local/bin
[[ -d "$HOME/.local/bin" ]] && export PATH="$HOME/.local/bin:$PATH"

# WSL
[[ -d "/usr/lib/wsl/lib" ]] && export PATH="/usr/lib/wsl/lib:$PATH"


# ============================================
# Zsh basics
# ============================================

# Colors (needed for the prompt theme below)
autoload -U colors && colors

# History
HISTFILE=$HOME/.zsh_history
HISTSIZE=50000
SAVEHIST=10000
setopt EXTENDED_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY

# Emacs key bindings (zsh would otherwise pick vi mode because EDITOR=vim)
bindkey -e

# Required so $(...) in PROMPT is re-evaluated each render
setopt PROMPT_SUBST


# ============================================
# Completion
# ============================================

ZSH_PLUGINS="${ZSH_PLUGINS:-$HOME/.zsh/plugins}"

autoload -Uz compinit
# -u skips the insecure-directory check (shared linuxbrew owns site-functions
# as another user). Same effect as omz's ZSH_DISABLE_COMPFIX.
compinit -u


# ============================================
# Plugins
# ============================================

# zsh-autosuggestions
[[ -f "$ZSH_PLUGINS/zsh-autosuggestions/zsh-autosuggestions.zsh" ]] && \
    source "$ZSH_PLUGINS/zsh-autosuggestions/zsh-autosuggestions.zsh"

# zsh-syntax-highlighting (must be sourced last)
[[ -f "$ZSH_PLUGINS/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]] && \
    source "$ZSH_PLUGINS/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"


# ============================================
# Prompt (replicates the oh-my-zsh "dst" theme)
# ============================================

ZSH_THEME_GIT_PROMPT_PREFIX=" %{$fg[green]%}"
ZSH_THEME_GIT_PROMPT_SUFFIX="%{$reset_color%}"
ZSH_THEME_GIT_PROMPT_DIRTY="%{$fg[red]%}!"
ZSH_THEME_GIT_PROMPT_CLEAN=""

git_prompt_info() {
    local ref
    ref=$(command git symbolic-ref --short HEAD 2>/dev/null) \
        || ref=$(command git rev-parse --short HEAD 2>/dev/null) \
        || return 0
    local dirty=""
    if [[ -n $(command git status --porcelain --ignore-submodules 2>/dev/null) ]]; then
        dirty="$ZSH_THEME_GIT_PROMPT_DIRTY"
    fi
    echo "${ZSH_THEME_GIT_PROMPT_PREFIX}${ref}${dirty}${ZSH_THEME_GIT_PROMPT_SUFFIX}"
}

prompt_char() {
    if [ $UID -eq 0 ]; then echo "%{$fg[red]%}#%{$reset_color%}"; else echo '$'; fi
}

PROMPT='%(?, ,%{$fg[red]%}FAIL%{$reset_color%}
)
%{$fg[magenta]%}%n%{$reset_color%}@%{$fg[yellow]%}%m%{$reset_color%}: %{$fg_bold[blue]%}%~%{$reset_color%}$(git_prompt_info)
$(prompt_char) '

RPROMPT='%{$fg[green]%}[%*]%{$reset_color%}'


# ============================================
# Terminal title (cwd at prompt, command name while running)
# ============================================

autoload -Uz add-zsh-hook
_term_title_precmd()  { print -Pn "\e]2;%~\a" }
_term_title_preexec() { print -Pn "\e]2;${1//[^[:print:]]/}\a" }
add-zsh-hook precmd  _term_title_precmd
add-zsh-hook preexec _term_title_preexec


# ============================================
# Environment
# ============================================

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export TERM=xterm-256color
export EDITOR=vim


# ============================================
# Shell options
# ============================================

unsetopt AUTO_CD

bindkey '^Q' backward-word
bindkey '^W' forward-word


# ============================================
# Aliases
# ============================================

alias tmux="tmux -u"
alias dush="du -sh -- *(D)"
alias path='echo $PATH | tr ":" "\n" | nl'

# Directory navigation (replicates omz lib/directories.zsh)
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ......='cd ../../../../..'

# Ubuntu binary name compatibility
command -v batcat >/dev/null && alias bat='batcat'
command -v fdfind >/dev/null && alias fd='fdfind'

# eza
alias l="eza -a"
alias ll="eza -al --git --time-style=long-iso"
alias llm="eza -al --git --time-style=long-iso --sort modified"
alias lt="eza -a --tree"
alias ltl="eza -a --tree --level 1"
alias ltll="eza -a --tree --level 2"
alias ltlll="eza -a --tree --level 3"

# git
alias gs="git status"
alias gd="git diff"
alias gdh="git diff head~1"
alias gdhh="git diff head~2"
alias gdhhh="git diff head~3"
alias gdhhhh="git diff head~4"
alias gds="git diff --stat"
alias gdsh="git diff --stat head~1"
alias gdshh="git diff --stat head~2"
alias gdshhh="git diff --stat head~3"
alias gdshhhh="git diff --stat head~4"
alias gdsg="git diff --staged"
alias gdsgs="git diff --staged --stat"
alias ga="git add"
alias gc='git commit'
alias gco='git checkout'
alias glp='git log -p'     # orignal format
alias gl="git log --graph --all \
  --pretty=format:'%C(auto)%h%Creset %Cgreen%ad%Creset %Cblue%an%Creset%C(auto)%d%Creset %s' \
  --date=short"
alias gll="git log --graph --all \
  --pretty=format:'%C(auto)%h%Creset %Cgreen%ad%Creset %Cblue%an <%ae>%Creset%C(auto)%d%Creset%n%s' \
  --date=format:'%Y-%m-%d %H:%M:%S'"


# ============================================
# Functions
# ============================================

# interactive git checkout with fzf
gcoi() {
  git branch --all --format='%(refname:short)' | fzf | xargs git checkout
}

# inline git commit with message
gcm() {
  if [[ $# -eq 0 ]]; then
    echo -n "Commit message: "
    read -r msg
    git commit -m "$msg"
  else
    git commit -m "$*"
  fi
}


# ============================================
# Python
# ============================================

alias python='uv run python'
alias py='uv run python'

if command -v uv > /dev/null; then
    eval "$(uv generate-shell-completion zsh)"
fi


# ============================================
# Tools
# ============================================

# zoxide
eval "$(zoxide init zsh)"

# direnv
if command -v direnv > /dev/null; then
    eval "$(direnv hook zsh)"
fi

# fzf
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Use fd for fzf: fast, respects .gitignore, includes hidden files
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="fd --type f --hidden --exclude .git . $HOME"

# Preview file content using bat (https://github.com/sharkdp/bat)
export FZF_CTRL_T_OPTS="
  --preview 'bat -n --color=always {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"

# CTRL-/ to toggle small preview window to see the full command
# CTRL-Y to copy the command into clipboard using pbcopy
export FZF_CTRL_R_OPTS="
  --preview 'echo {}' --preview-window up:3:hidden:wrap
  --bind 'ctrl-/:toggle-preview'
  --bind 'ctrl-y:execute-silent(echo -n {2..} | pbcopy)+abort'
  --color header:italic
  --header 'Press CTRL-Y to copy command into clipboard'"

# ff - Flexible File Finder
source "$HOME/dotfiles/zsh/ff.sh"


# ============================================
# Local config (machine-specific overrides)
# ============================================

[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local



# ============================================
# no-op (for exit code 0)
# ============================================

true
